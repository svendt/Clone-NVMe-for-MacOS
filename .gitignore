# =============================================================================
# .gitignore for clone_and_restore_svdt.sh
# =============================================================================

# ─── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ─── Backup images ────────────────────────────────────────────────────────────
# Excluded because real disk images can be hundreds of gigabytes.
# To commit a small test image intentionally: git add -f filename.img.gz
*.img
*.img.gz
*.img.gz.size
*.img.gz.sha256

# ─── Script runtime output ────────────────────────────────────────────────────
# Log files generated by clone_and_restore_svdt.sh on every run
*.log
logs/

# Temp images written during backup (atomic rename pattern: image.img.gz.tmp.PID)
*.tmp
*.tmp.*
tmp/

# Lock directory used by single-instance guard
*.lock
*.pid

# ─── Editor and IDE files ─────────────────────────────────────────────────────
*.swp
*.swo
.vscode/
.idea/
